<Window x:Class="AutoPlot.Views.AxisCalibrationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="軸キャリブレーション"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">

    <Grid Margin="16" Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Theme -->
        <GroupBox Header="テーマ" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Margin="4">
                <TextBlock Text="Color Theme:" Width="90" VerticalAlignment="Center"/>
                <ComboBox Width="180"
                          ItemsSource="{Binding ThemeOptions}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Value"
                          SelectedValue="{Binding SelectedTheme, Mode=TwoWay}"/>
            </StackPanel>
        </GroupBox>

        <!-- X axis -->
        <GroupBox Header="X軸" Grid.Row="1" Margin="0,0,0,8">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Min:" Width="40" VerticalAlignment="Center"/>
                    <TextBox Width="100" Text="{Binding XMin}"/>
                    <TextBlock Text="Max:" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    <TextBox Width="100" Text="{Binding XMax}"/>
                </StackPanel>
                <Border 
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="6"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        Background="{DynamicResource AppSurfaceAltBrush}">
                    <CheckBox
                        Content=": Logスケール"
                        IsChecked="{Binding IsXLog}" />
                </Border>

            </StackPanel>
        </GroupBox>

        <!-- Y axis -->
        <GroupBox Header="Y軸" Grid.Row="2">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Min:" Width="40" VerticalAlignment="Center"/>
                    <TextBox Width="100" Text="{Binding YMin}" />
                    <TextBlock Text="Max:" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    <TextBox Width="100" Text="{Binding YMax}"/>
                </StackPanel>
                <Border
                    Padding="6"
                    CornerRadius="4"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    Background="{DynamicResource AppSurfaceAltBrush}">

                    <CheckBox
                        Content=": Logスケール"
                        IsChecked="{Binding IsYLog}" />
                </Border>
            </StackPanel>
        </GroupBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="OK"
                    Width="80"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="Ok_Click"/>
            <Button Content="Cancel"
                    Width="80"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
