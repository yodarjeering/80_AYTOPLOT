<Window x:Class="AutoPlot.Views.SeriesTraceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Trace Series"
        Width="900"
        Height="650"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Margin="0,0,0,10"
                    VerticalAlignment="Center">
            <TextBlock Text="Series count:"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0" />
            <TextBox Width="80"
                     Text="{Binding SeriesCount, UpdateSourceTrigger=PropertyChanged}" />
            <Button Content="Start Trace"
                    Margin="10,0,0,0"
                    Padding="12,4"
                    Command="{Binding StartTraceCommand}"
                    Click="StartTraceButton_Click" />
            <Button Content="Undo"
                    Margin="10,0,0,0"
                    Padding="12,4"
                    Command="{Binding UndoCommand}"
                    Click="EditTraceButton_Click" />
            <Button Content="Redo"
                    Margin="10,0,0,0"
                    Padding="12,4"
                    Command="{Binding RedoCommand}"
                    Click="EditTraceButton_Click" />
            <Button Content="Reset"
                    Margin="10,0,0,0"
                    Padding="12,4"
                    Command="{Binding ResetTraceCommand}"
                    Click="EditTraceButton_Click" />
            <Button Content="OK"
                    Margin="10,0,0,0"
                    Padding="12,4"
                    Command="{Binding OkCommand}"
                    Click="OkButton_Click" />
            <TextBlock Text="{Binding InstructionText}"
                       Margin="20,0,0,0"
                       VerticalAlignment="Center"
                       FontWeight="Bold" />
        </StackPanel>

        <Border BorderBrush="Gray"
                BorderThickness="1"
                Background="White">
            <Grid>
                <Image x:Name="PlotImageControl"
                       Stretch="Uniform"
                       Source="{Binding PlotImage}" />
                <Canvas x:Name="TraceCanvas"
                        Background="Transparent"
                        MouseLeftButtonDown="TraceCanvas_MouseLeftButtonDown"
                        MouseMove="TraceCanvas_MouseMove"
                        MouseLeftButtonUp="TraceCanvas_MouseLeftButtonUp" />
            </Grid>
        </Border>
    </DockPanel>
</Window>
