<Window x:Class="AutoPlot.Views.SeriesTraceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Trace Series"
        Width="900"
        Height="650"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource AppTextBrush}">
        <DockPanel Margin="10">

        <!-- Top: series count and instruction -->
        <StackPanel DockPanel.Dock="Top"
                        Orientation="Horizontal"
                        Margin="0,0,0,10"
                        VerticalAlignment="Center">

                <TextBlock Text="系列数を入力してください:"
                        VerticalAlignment="Center"
                        Margin="0,0,6,0" />

                <TextBox Width="80"
                        Text="{Binding SeriesCount, UpdateSourceTrigger=PropertyChanged}" />

                <Button Content="Start Trace"
                        Margin="10,0,8,0"
                        Padding="12,4"
                        Command="{Binding StartTraceCommand}"
                        Click="StartTraceButton_Click" />

                        
                <Button Content="⟲"
                        Margin="0,0,8,0"
                        Padding="12,4"
                        Command="{Binding UndoCommand}"
                        Click="EditTraceButton_Click" />

                <Button Content="⟳"
                        Margin="0,0,8,0"
                        Padding="12,4"
                        Command="{Binding RedoCommand}"
                        Click="EditTraceButton_Click" />

                <Button Content="Reset"
                        Margin="0,0,8,0"
                        Padding="12,4"
                        Command="{Binding ResetTraceCommand}"
                        Click="EditTraceButton_Click" />

                <TextBlock Text="{Binding InstructionText}"
                        Margin="20,0,0,0"
                        VerticalAlignment="Center"
                        FontWeight="Bold" />
        </StackPanel>

        <!-- Bottom: operation buttons -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="0,10,0,0"
                Margin="0,10,0,0">

                <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">


                <Button Content="OK"
                        Padding="12,4"
                        Margin="0,0,8,0"
                        Command="{Binding OkCommand}"
                        Click="OkButton_Click" />

                <Button Content="Cancel"
                        Width="100"
                        Height="32"
                        Click="CancelButton_Click"/>

                </StackPanel>
        </Border>

        <!-- Center: image and trace canvas -->
        <Border BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                Background="{DynamicResource AppSurfaceBrush}">
                <Grid>
                <Image x:Name="PlotImageControl"
                        Stretch="Uniform"
                        Source="{Binding PlotImage}" />
                <Canvas x:Name="TraceCanvas"
                        Background="Transparent"
                        MouseLeftButtonDown="TraceCanvas_MouseLeftButtonDown"
                        MouseMove="TraceCanvas_MouseMove"
                        MouseLeftButtonUp="TraceCanvas_MouseLeftButtonUp" />
                </Grid>
        </Border>
        </DockPanel>
</Window>
